# ─── SERVER ───────────────────────────────
PORT=
NODE_ENV=

# ─── MONGODB ──────────────────────────────
MONGO_URI=

# ─── JWT ──────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# ─── EMAIL (Nodemailer) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars
EMAIL_FROM=CognifyPM <your_gmail@gmail.com>

# ─── OPENAI ───────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini


# ─── GITHUB OAUTH ─────────────────────────
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_REDIRECT_URI=http://localhost:5000/api/employee/github/callback

# ─── CLOUDINARY ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── REDIS ────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_if_any

# ─── FRONTEND ─────────────────────────────
CLIENT_URL=http://localhost:3000
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ─── WEBRTC TURN (optional, prod only) ────
TURN_SERVER_URL=turn:your_turn_server_url
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential


# ─── PM2 CLUSTERING ───────────────────────
PM2_INSTANCES=max
PM2_EXEC_MODE=cluster

# ─── ACTUAL CODEBASE VARS (ADDED) ─────────
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_pass
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRES=7d
FRONTEND_URL=http://localhost:5173
RAZORPAY_KEY_ID=your_razorpay_key_id
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@cognifypm.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
